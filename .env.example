# Optional overrides for `docker compose up`
# Copy to .env and adjust as needed.

# JWT secrets (REQUIRED for production!)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed browser origins for the API
CORS_ORIGIN=http://localhost:3000

# What URL the *browser* uses to call the API (baked into Next.js build)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Field Force Manager
